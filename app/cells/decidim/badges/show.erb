<% current_organization.public_participatory_spaces.each do |space| %>
  <div class="profile__badge-banner">
    <%= icon "information-line" %>
    <div>
      <h2 class="h4"><%= translated_attribute(space.title) %></h2>

      <img src="<%= space.hero_image.url %>">
      <p>
        This space has the following badges: <br />
        Perform any action this space to get some badges.
      </p>
    </div>
  </div>

  <div class="profile__badge-grid">
    <% available_badges.each do |badge| %>
      <%= cell "decidim/badge", model, badge: %>
    <% end %>
  </div>
<% end  %>